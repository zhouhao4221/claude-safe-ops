{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/sensitive-input-guard.sh",
            "timeout": 3,
            "statusMessage": "Checking for sensitive data..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/validate-hooks.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./scripts/risk-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/guard-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/audit-log.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
